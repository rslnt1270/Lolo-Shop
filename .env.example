# Copia este archivo a .env y llena los valores reales.
# NUNCA commitees el archivo .env — contiene credenciales.

# Cadena de conexión de PostgreSQL (Neon)
DATABASE_URL="postgresql://usuario:password@host/db?sslmode=require"

# Genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Meta Cloud API (bot de WhatsApp). Sin token, el bot corre en modo simulado (consola).
WHATSAPP_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
# App Secret de la app de Meta: valida la firma X-Hub-Signature-256 del webhook.
WHATSAPP_APP_SECRET=""

# Clave para /api/bot/products (n8n). Sin ella, el endpoint responde 503.
BOT_API_KEY=""

# Número de WhatsApp del catálogo público (con código de país, ej. 5215555555555)
NEXT_PUBLIC_WHATSAPP_NUMBER=""

# Opcionales: contraseñas que usará prisma/seed.ts (si no, usa valores de desarrollo)
SEED_PASSWORD_LOLO=""
SEED_PASSWORD_ENCARGADO=""
SEED_PASSWORD_COLAB1=""
SEED_PASSWORD_COLAB2=""
