{
  "mcpServers": {
    "shopify-dev": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@shopify/dev-mcp@latest"
      ],
      "env": {}
    },
    "graphify": {
      "type": "stdio",
      "command": "graphify-mcp",
      "args": [
        "--graph",
        "graphify-out/graph.json",
        "--transport",
        "stdio"
      ],
      "env": {}
    },
    "postgres": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${DATABASE_URL}"
      ],
      "env": {}
    }
  }
}
